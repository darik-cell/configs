@dataclass
class RenderedPage:
    title: str
    content_html: str
    toc_html: str
    mtime_ns: int | None = None


@dataclass
class ServerProbe:
    kind: str
    host: str
    port: int
    pid: int | None = None
    started_at: int | None = None
    detail: str | None = None


class QuietRequestHandler(WSGIRequestHandler):
    def log(self, _type: str, _message: str, *args: object) -> None:
        return

    def log_request(self, code: int | str = "-", size: int | str = "-") -> None:
        return

    def log_error(self, _format: str, *args: object) -> None:
        return


def state_dir_url() -> str:
    return str(STATE_FILE)


def slugify(value: str) -> str:
    normalized = re.sub(r"[^\w\s-]", "", value, flags=re.UNICODE).strip().lower()
    normalized = re.sub(r"[-\s]+", "-", normalized, flags=re.UNICODE)
    return normalized or "section"


def app_url(host: str, port: int) -> str:
    return f"http://{host}:{port}"


def ensure_state_dir() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)


def write_state_file(payload: dict[str, object]) -> None:
    ensure_state_dir()
    tmp_path = STATE_FILE.with_suffix(".json.tmp")
    tmp_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    tmp_path.replace(STATE_FILE)


def read_state_file() -> dict[str, object] | None:
    try:
        raw = json.loads(STATE_FILE.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return None
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(raw, dict):
        return None
    return raw


def remove_state_file() -> None:
    with contextlib.suppress(FileNotFoundError):
        STATE_FILE.unlink()


def remove_state_if_pid_matches(pid: int) -> None:
    state = read_state_file()
    if not state:
        return
    if int(state.get("pid", -1)) == pid:
        remove_state_file()


def build_state_payload(host: str, port: int, pid: int, started_at: int) -> dict[str, object]:
    return {
        "version": STATE_VERSION,
        "host": host,
        "port": port,
        "pid": pid,
        "started_at": started_at,
        "script": str(SCRIPT_PATH),
    }


def normalize_base_dir(cwd_value: str | None) -> Path:
    if not cwd_value or not cwd_value.strip():
        return LAUNCH_CWD
    expanded = os.path.expanduser(cwd_value.strip())
    candidate = Path(expanded)
    if not candidate.is_absolute():
        candidate = (LAUNCH_CWD / candidate).resolve()
    else:
        candidate = candidate.resolve()
    if candidate.exists() and candidate.is_dir():
        return candidate
    return LAUNCH_CWD


def highlight_code(code: str, language: str, _attrs: str) -> str:
    language = (language or "").strip()
    try:
        lexer = get_lexer_by_name(language) if language else TextLexer()
    except ClassNotFound:
        lexer = TextLexer()
    return highlight(code, lexer, PYGMENTS_FORMATTER)


def build_markdown_renderer() -> MarkdownIt:
    parser = MarkdownIt("commonmark", {"html": False})
    parser.enable("table")
    parser.use(tasklists_plugin)
    parser.renderer.rules["fence"] = render_fence
    parser.renderer.rules["code_block"] = render_code_block
    parser.renderer.rules["code_inline"] = render_inline_code
    return parser


def encode_copy_payload(text: str) -> str:
    return base64.b64encode(text.encode("utf-8")).decode("ascii")


def render_copy_link(copy_text: str, classes: str, label: str) -> str:
    payload = html.escape(encode_copy_payload(copy_text), quote=True)
    return (
        f'<a href="#copy" class="copy-link {classes}" '
        f'data-copy-b64="{payload}" aria-label="{html.escape(label, quote=True)}"></a>'
    )


def render_inline_code(tokens: list, index: int, _options: dict, _env: dict) -> str:
    token = tokens[index]
    code_html = html.escape(token.content)
    copy_link = render_copy_link(token.content, "copy-link-inline", "Copy inline code")
    return f'<span class="inline-code-wrap"><code>{code_html}</code>{copy_link}</span>'


def render_fence(tokens: list, index: int, _options: dict, _env: dict) -> str:
    token = tokens[index]
    info = (token.info or "").strip()
    language = info.split(None, 1)[0] if info else ""
    highlighted = highlight_code(token.content, language, "")
    copy_link = render_copy_link(token.content, "copy-link-block", "Copy code block")
    return f'<div class="code-block-wrap">{copy_link}{highlighted}</div>'


def render_code_block(tokens: list, index: int, _options: dict, _env: dict) -> str:
    code = tokens[index].content
    highlighted = highlight_code(code, "", "")
    copy_link = render_copy_link(code, "copy-link-block", "Copy code block")
    return f'<div class="code-block-wrap">{copy_link}{highlighted}</div>'


def extract_inline_text(tokens: Iterable) -> str:
    parts: list[str] = []
    for token in tokens or []:
        if token.type == "image":
            parts.append(token.content)
        elif token.type == "code_inline":
            parts.append(token.content)
        elif token.type == "text":
            parts.append(token.content)
        elif token.children:
            parts.append(extract_inline_text(token.children))
        elif token.content:
            parts.append(token.content)
    return "".join(parts).strip()


def safe_remote_url(raw_url: str) -> str:
    parts = urlsplit(raw_url)
    scheme = parts.scheme.lower()
    if scheme and scheme not in ALLOWED_LINK_SCHEMES:
        return "#"
    return raw_url


def resolve_user_path(path_value: str, cwd_value: str | None = None) -> Path:
    expanded = os.path.expanduser(path_value.strip())
    path = Path(expanded)
    if not path.is_absolute():
        path = normalize_base_dir(cwd_value) / path
    return path.resolve()


def rewrite_local_url(raw_url: str, base_dir: Path | None, *, asset_mode: bool = False) -> str:
    if not raw_url:
        return raw_url
    if base_dir is None:
        return safe_remote_url(raw_url)
    if raw_url.startswith("#"):
        return raw_url

    parts = urlsplit(raw_url)
    if parts.scheme or parts.netloc:
        return safe_remote_url(raw_url)
    if not parts.path:
        return raw_url

    candidate = Path(os.path.expanduser(parts.path))
    if not candidate.is_absolute():
        candidate = (base_dir / candidate).resolve()
    else:
        candidate = candidate.resolve()

    fragment = f"#{parts.fragment}" if parts.fragment else ""
    query = urlencode({"path": str(candidate)})
    if not asset_mode and candidate.suffix.lower() in MARKDOWN_EXTENSIONS:
        return f"/view?{query}{fragment}"
    return f"/asset?{query}"


def collect_and_rewrite_tokens(tokens: list, base_dir: Path | None) -> tuple[str, list[tuple[int, str, str]]]:
    heading_counts: dict[str, int] = {}
    headings: list[tuple[int, str, str]] = []

    def walk(token_list: list) -> None:
        for index, token in enumerate(token_list):
            if token.type == "heading_open":
                inline_token = token_list[index + 1] if index + 1 < len(token_list) else None
                inline_tokens = inline_token.children if inline_token and inline_token.type == "inline" else []
                text = extract_inline_text(inline_tokens) or token.tag.upper()
                slug = slugify(text)
                if slug in heading_counts:
                    heading_counts[slug] += 1
                    slug = f"{slug}-{heading_counts[slug]}"
                else:
                    heading_counts[slug] = 0
                token.attrSet("id", slug)
                level = int(token.tag[1]) if len(token.tag) == 2 and token.tag.startswith("h") else 1
                headings.append((level, text, slug))

            if token.type == "inline" and token.children:
                walk(token.children)
                continue

            if token.type == "link_open":
                href = token.attrGet("href")
                if href is not None:
                    token.attrSet("href", rewrite_local_url(href, base_dir))
                    token.attrSet("rel", "noreferrer")
                    token.attrSet("target", "_blank" if urlsplit(href).scheme in {"http", "https"} else "_self")
            elif token.type == "image":
                src = token.attrGet("src")
                if src is not None:
                    token.attrSet("src", rewrite_local_url(src, base_dir, asset_mode=True))

    walk(tokens)
    title = next((text for level, text, _slug in headings if level == 1), headings[0][1] if headings else "Markdown Viewer")
    return title, headings


def build_toc_html(headings: list[tuple[int, str, str]]) -> str:
    if not headings:
        return '<p class="toc-empty">No headings found.</p>'

    items = ["<ul class='toc-list'>"]
    for level, text, anchor in headings:
        items.append(f"<li class='toc-level-{level}'><a href='#{html.escape(anchor)}'>{html.escape(text)}</a></li>")
    items.append("</ul>")
    return "".join(items)


def render_markdown(text: str, source_path: Path | None = None) -> RenderedPage:
    parser = build_markdown_renderer()
    tokens = parser.parse(text)
    title, headings = collect_and_rewrite_tokens(tokens, source_path.parent if source_path else None)
    content_html = parser.renderer.render(tokens, parser.options, {})
    return RenderedPage(title=title, content_html=content_html, toc_html=build_toc_html(headings))


def normalize_markdown_path(path_value: str, cwd_value: str | None = None) -> Path:
    if not path_value or not path_value.strip():
        raise ValueError("Path is required.")
    try:
        path = resolve_user_path(path_value, cwd_value)
    except (OSError, RuntimeError, ValueError) as exc:
        raise ValueError(f"Invalid path: {exc}") from exc

    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")
    if not path.is_file():
        raise ValueError(f"Path is not a file: {path}")
    if path.suffix.lower() not in MARKDOWN_EXTENSIONS:
        raise ValueError("Only .md and .markdown files are supported.")
    return path


def read_markdown_file(path_value: str, cwd_value: str | None = None) -> tuple[Path, str]:
    path = normalize_markdown_path(path_value, cwd_value)
    return path, path.read_text(encoding="utf-8")


def render_home(error: str | None = None, cwd_hint: str | None = None) -> str:
    return render_template_string(
        HOME_TEMPLATE,
        base_css=BASE_CSS,
        error=error,
        cwd_hint=str(normalize_base_dir(cwd_hint)),
    )


def render_document_page(
    *,
    page: RenderedPage,
    source_name: str,
    source_description: str,
    source_path: str | None,
    upload_mode: bool,
    open_home_cwd: str | None = None,
) -> str:
    home_cwd = open_home_cwd or str(LAUNCH_CWD)
    return render_template_string(
        VIEW_TEMPLATE,
        title=page.title,
        base_css=BASE_CSS,
        content_html=page.content_html,
        toc_html=page.toc_html,
        source_name=source_name,
        source_description=source_description,
        source_path=source_path,
        reload_href=f"/view?{urlencode({'path': source_path})}" if source_path else None,
        open_home_href=f"/?{urlencode({'cwd': home_cwd})}",
        live_update=not upload_mode and bool(source_path),
        upload_mode=upload_mode,
        mtime_ns=page.mtime_ns or 0,
    )


@APP.route("/")
def home() -> str:
    return render_home(cwd_hint=request.args.get("cwd"))


@APP.route("/health")
def health() -> Response:
    return jsonify(
        {
            "app": "mdview",
            "host": SERVER_METADATA["host"],
            "port": SERVER_METADATA["port"],
            "pid": SERVER_METADATA["pid"],
            "started_at": SERVER_METADATA["started_at"],
        }
    )


@APP.route("/view")
def view_markdown() -> tuple[str, int] | str:
    path_value = request.args.get("path", "")
    cwd_value = request.args.get("cwd")
    try:
        path, content = read_markdown_file(path_value, cwd_value)
    except (ValueError, FileNotFoundError, PermissionError, UnicodeDecodeError) as exc:
        return render_home(str(exc), cwd_hint=cwd_value), 400

    page = render_markdown(content, path)
    page.mtime_ns = path.stat().st_mtime_ns
    return render_document_page(
        page=page,
        source_name=path.name,
        source_description=str(path),
        source_path=str(path),
        upload_mode=False,
        open_home_cwd=str(path.parent),
    )


@APP.route("/render-upload", methods=["POST"])
def render_upload() -> tuple[str, int] | str:
    uploaded = request.files.get("file")
    if uploaded is None or not uploaded.filename:
        return render_home("Choose a Markdown file first."), 400
    suffix = Path(uploaded.filename).suffix.lower()
    if suffix not in MARKDOWN_EXTENSIONS:
        return render_home("Only .md and .markdown files are supported."), 400
    try:
        text = uploaded.read().decode("utf-8")
    except UnicodeDecodeError:
        return render_home("Uploaded file must be valid UTF-8 Markdown."), 400

    page = render_markdown(text, None)
    return render_document_page(
        page=page,
        source_name=uploaded.filename,
        source_description="Uploaded file rendered in memory.",
        source_path=None,
        upload_mode=True,
    )


@APP.route("/asset")
def serve_asset() -> Response:
    path_value = request.args.get("path", "")
    try:
        path = resolve_user_path(path_value)
    except (OSError, RuntimeError, ValueError) as exc:
        return Response(str(exc), status=400, mimetype="text/plain")
    if not path.exists() or not path.is_file():
        return Response("Asset not found.", status=404, mimetype="text/plain")

    mime_type = mimetypes.guess_type(path.name)[0]
    return send_file(path, mimetype=mime_type)


@APP.route("/meta")
def meta() -> Response:
    path_value = request.args.get("path", "")
    try:
        path = normalize_markdown_path(path_value)
    except FileNotFoundError:
        return jsonify({"exists": False}), 404
    except (ValueError, PermissionError, UnicodeDecodeError) as exc:
        return jsonify({"exists": False, "error": str(exc)}), 400

    stat = path.stat()
    return jsonify({"exists": True, "mtime_ns": stat.st_mtime_ns, "size": stat.st_size})


@APP.route("/fragment")
def fragment() -> Response:
    path_value = request.args.get("path", "")
    try:
        path, content = read_markdown_file(path_value)
    except FileNotFoundError:
        return jsonify({"error": "File not found."}), 404
    except (ValueError, PermissionError, UnicodeDecodeError) as exc:
        return jsonify({"error": str(exc)}), 400

    page = render_markdown(content, path)
    page.mtime_ns = path.stat().st_mtime_ns
    return jsonify(
        {
            "title": page.title,
            "content_html": page.content_html,
            "toc_html": page.toc_html,
            "mtime_ns": page.mtime_ns,
        }
    )


def configure_server_logging() -> None:
    APP.logger.disabled = True
    logging.getLogger("werkzeug").disabled = True


def is_connection_refused(error: urllib.error.URLError) -> bool:
    reason = getattr(error, "reason", None)
    if isinstance(reason, ConnectionRefusedError):
        return True
    if isinstance(reason, OSError) and getattr(reason, "errno", None) in {111, 61}:
        return True
    return False


def read_process_cmdline(pid: int) -> list[str]:
    try:
        raw = (Path("/proc") / str(pid) / "cmdline").read_bytes()
    except (FileNotFoundError, PermissionError, ProcessLookupError, OSError):
        return []
    return [part for part in raw.decode("utf-8", errors="ignore").split("\0") if part]


def process_exists(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def find_listener_inodes(host: str, port: int) -> set[str]:
    try:
        packed_host = socket.inet_aton(host)
    except OSError:
        return set()

    encoded_host = "".join(f"{byte:02X}" for byte in reversed(packed_host))
    encoded_port = f"{port:04X}"
    target = f"{encoded_host}:{encoded_port}"
    inodes: set[str] = set()

    try:
        lines = Path("/proc/net/tcp").read_text(encoding="utf-8").splitlines()
    except (FileNotFoundError, PermissionError, OSError):
        return set()

    for line in lines[1:]:
        parts = line.split()
        if len(parts) < 10:
            continue
        if parts[1] == target and parts[3] == "0A":
            inodes.add(parts[9])
    return inodes


def find_listener_pids(host: str, port: int) -> list[int]:
    inodes = find_listener_inodes(host, port)
    if not inodes:
        return []

    pids: set[int] = set()
    proc_root = Path("/proc")
    for proc_entry in proc_root.iterdir():
        if not proc_entry.name.isdigit():
            continue
        fd_dir = proc_entry / "fd"
        try:
            fd_entries = list(fd_dir.iterdir())
        except (FileNotFoundError, PermissionError, OSError):
            continue

        for fd_entry in fd_entries:
            try:
                target = os.readlink(fd_entry)
            except OSError:
                continue
            if target.startswith("socket:[") and target.endswith("]"):
                inode = target[8:-1]
                if inode in inodes:
                    pids.add(int(proc_entry.name))
                    break
    return sorted(pids)


def matches_flag_value(cmdline: list[str], flag: str, expected: str) -> bool:
    try:
        index = cmdline.index(flag)
    except ValueError:
        return False
    return index + 1 < len(cmdline) and cmdline[index + 1] == expected


def is_mdview_serve_process(pid: int, host: str, port: int) -> bool:
    cmdline = read_process_cmdline(pid)
    if not cmdline:
        return False

    script_match = False
    for candidate in (cmdline[0], cmdline[1] if len(cmdline) > 1 else ""):
        if not candidate:
            continue
        with contextlib.suppress(OSError, RuntimeError, ValueError):
            if Path(candidate).resolve() == SCRIPT_PATH:
                script_match = True
                break

    if not script_match:
        return False
    if "serve" not in cmdline:
        return False
    if not matches_flag_value(cmdline, "--host", host):
        return False
    if not matches_flag_value(cmdline, "--port", str(port)):
        return False
    return True


def find_stale_mdview_pid(host: str, port: int, preferred_pid: int | None = None) -> int | None:
    candidate_pids = find_listener_pids(host, port)
    if preferred_pid is not None:
        ordered = [preferred_pid] + [pid for pid in candidate_pids if pid != preferred_pid]
    else:
        ordered = candidate_pids

    for pid in ordered:
        if is_mdview_serve_process(pid, host, port):
            return pid
    return None


def wait_for_pid_exit(pid: int, timeout_seconds: float) -> bool:
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        if not process_exists(pid):
            return True
        time.sleep(0.05)
    return not process_exists(pid)


def wait_for_port_release(host: str, port: int, timeout_seconds: float) -> bool:
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        if not find_listener_pids(host, port):
            return True
        time.sleep(0.05)
    return not find_listener_pids(host, port)


def terminate_mdview_process(pid: int, host: str, port: int) -> None:
    if not is_mdview_serve_process(pid, host, port):
        raise SystemExit(f"Refusing to terminate non-mdview process on {app_url(host, port)} (pid {pid}).")

    if process_exists(pid):
        with contextlib.suppress(ProcessLookupError):
            os.kill(pid, signal.SIGTERM)
        if wait_for_pid_exit(pid, SERVER_STOP_TIMEOUT_SECONDS) and wait_for_port_release(host, port, 1.0):
            return

    if process_exists(pid):
        with contextlib.suppress(ProcessLookupError):
            os.kill(pid, signal.SIGKILL)
        if wait_for_pid_exit(pid, 1.0) and wait_for_port_release(host, port, 1.0):
            return

    if not process_exists(pid) and wait_for_port_release(host, port, 1.0):
        return
    raise SystemExit(f"Failed to terminate stale mdview server on {app_url(host, port)} (pid {pid}).")


def inspect_server_on_port(host: str, port: int, preferred_pid: int | None = None) -> ServerProbe:
    probe = probe_server(port, host)
    if probe.kind != "other":
        return probe

    stale_pid = find_stale_mdview_pid(host, port, preferred_pid)
    if stale_pid is not None:
        return ServerProbe(kind="stale", host=host, port=port, pid=stale_pid, detail=probe.detail)
    return probe


def probe_server(port: int, host: str = DEFAULT_HOST) -> ServerProbe:
    request_url = f"{app_url(host, port)}/health"
    req = urllib.request.Request(request_url, headers={"Accept": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=HEALTH_TIMEOUT_SECONDS) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        return ServerProbe(kind="other", host=host, port=port, detail=f"unexpected HTTP {exc.code}")
    except urllib.error.URLError as exc:
        if is_connection_refused(exc):
            return ServerProbe(kind="none", host=host, port=port)
        return ServerProbe(kind="other", host=host, port=port, detail=str(exc.reason))
    except (TimeoutError, socket.timeout, json.JSONDecodeError, UnicodeDecodeError):
        return ServerProbe(kind="other", host=host, port=port, detail="unexpected response")

    if payload.get("app") != "mdview":
        return ServerProbe(kind="other", host=host, port=port, detail="unexpected service")
    return ServerProbe(
        kind="mdview",
        host=str(payload.get("host", host)),
        port=int(payload.get("port", port)),
        pid=int(payload.get("pid")) if payload.get("pid") is not None else None,
        started_at=int(payload.get("started_at")) if payload.get("started_at") is not None else None,
    )


def adopt_probe_state(probe: ServerProbe) -> dict[str, object]:
    state = build_state_payload(
        host=probe.host,
        port=probe.port,
        pid=probe.pid or -1,
        started_at=probe.started_at or int(time.time()),
    )
    write_state_file(state)
    return state


def get_running_server(requested_port: int, port_was_explicit: bool) -> dict[str, object] | None:
    state = read_state_file()
    if state:
        state_host = str(state.get("host", DEFAULT_HOST))
        state_port = int(state.get("port", DEFAULT_PORT))
        preferred_pid = int(state.get("pid", -1))
        probe = inspect_server_on_port(state_host, state_port, preferred_pid if preferred_pid > 0 else None)
        if probe.kind == "mdview":
            if port_was_explicit and requested_port != state_port:
                raise SystemExit(
                    f"mdview server is already running on port {state_port}. Stop it before using --port {requested_port}."
                )
            fresh_state = build_state_payload(
                host=probe.host,
                port=probe.port,
                pid=probe.pid or int(state.get("pid", -1)),
                started_at=probe.started_at or int(state.get("started_at", int(time.time()))),
            )
            write_state_file(fresh_state)
            return fresh_state
        if probe.kind == "stale" and probe.pid is not None:
            terminate_mdview_process(probe.pid, state_host, state_port)
        remove_state_file()

    probe = inspect_server_on_port(DEFAULT_HOST, requested_port)
    if probe.kind == "mdview":
        return adopt_probe_state(probe)
    if probe.kind == "stale" and probe.pid is not None:
        terminate_mdview_process(probe.pid, DEFAULT_HOST, requested_port)
        remove_state_file()
        return None
    if probe.kind == "other":
        raise SystemExit(f"Port {requested_port} is already in use by another service.")
    return None


def start_server_process(port: int, host: str = DEFAULT_HOST) -> subprocess.Popen[bytes]:
    return subprocess.Popen(
        [sys.executable, str(SCRIPT_PATH), "serve", "--host", host, "--port", str(port)],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        cwd=str(LAUNCH_CWD),
        close_fds=True,
        start_new_session=True,
    )


def wait_for_server_ready(port: int, process: subprocess.Popen[bytes], host: str = DEFAULT_HOST) -> dict[str, object]:
    deadline = time.monotonic() + SERVER_START_TIMEOUT_SECONDS
    while time.monotonic() < deadline:
        probe = probe_server(port, host)
        if probe.kind == "mdview":
            return adopt_probe_state(probe)
        if probe.kind == "other":
            raise SystemExit(f"Port {port} is already in use by another service.")
        if process.poll() is not None:
            break
        time.sleep(0.1)
    raise SystemExit(f"Failed to start mdview server on port {port}.")


def ensure_server_running(requested_port: int, port_was_explicit: bool) -> dict[str, object]:
    running = get_running_server(requested_port, port_was_explicit)
    if running:
        return running
    process = start_server_process(requested_port, DEFAULT_HOST)
    return wait_for_server_ready(requested_port, process, DEFAULT_HOST)


def find_server_for_lifecycle() -> dict[str, object] | None:
    state = read_state_file()
    if state:
        state_host = str(state.get("host", DEFAULT_HOST))
        state_port = int(state.get("port", DEFAULT_PORT))
        preferred_pid = int(state.get("pid", -1))
        probe = inspect_server_on_port(state_host, state_port, preferred_pid if preferred_pid > 0 else None)
        if probe.kind == "mdview":
            fresh_state = build_state_payload(
                host=probe.host,
                port=probe.port,
                pid=probe.pid or int(state.get("pid", -1)),
                started_at=probe.started_at or int(state.get("started_at", int(time.time()))),
            )
            write_state_file(fresh_state)
            return fresh_state
        if probe.kind == "stale":
            stale_state = build_state_payload(
                host=probe.host,
                port=probe.port,
                pid=probe.pid or preferred_pid,
                started_at=int(state.get("started_at", int(time.time()))),
            )
            stale_state["status"] = "stale"
            write_state_file(stale_state)
            return stale_state
        remove_state_file()

    probe = inspect_server_on_port(DEFAULT_HOST, DEFAULT_PORT)
    if probe.kind == "mdview":
        return adopt_probe_state(probe)
    if probe.kind == "stale":
        stale_state = build_state_payload(
            host=probe.host,
            port=probe.port,
            pid=probe.pid or -1,
            started_at=int(time.time()),
        )
        stale_state["status"] = "stale"
        write_state_file(stale_state)
        return stale_state
    return None


def open_target_url(path_value: str | None, port: int, no_open: bool, port_was_explicit: bool) -> int:
    resolved_path: str | None = None
    if path_value:
        resolved_path = str(normalize_markdown_path(path_value))

    server = ensure_server_running(port, port_was_explicit=port_was_explicit)
    target_port = int(server["port"])
    if resolved_path:
        target_url = f"{app_url(DEFAULT_HOST, target_port)}/view?{urlencode({'path': resolved_path})}"
    else:
        target_url = f"{app_url(DEFAULT_HOST, target_port)}/?{urlencode({'cwd': str(LAUNCH_CWD)})}"
    if not no_open:
        webbrowser.open(target_url, new=2)
    return 0


def print_status() -> int:
    server = find_server_for_lifecycle()
    if not server:
        print("mdview server is not running.")
        print(f"state: {state_dir_url()}")
        return 1

    status = str(server.get("status", "running"))
    if status == "stale":
        print("mdview server is stale.")
    else:
        print("mdview server is running.")
    print(f"url: {app_url(str(server['host']), int(server['port']))}")
    print(f"pid: {int(server['pid'])}")
    print(f"state: {state_dir_url()}")
    return 0 if status == "running" else 1


def stop_server() -> int:
    server = find_server_for_lifecycle()
    if not server:
        print("mdview server is not running.")
        print(f"state: {state_dir_url()}")
        return 0

    pid = int(server["pid"])
    host = str(server["host"])
    port = int(server["port"])
    terminate_mdview_process(pid, host, port)
    remove_state_file()
    print(f"Stopped mdview server on {app_url(host, port)} (pid {pid}).")
    return 0


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    raw_args = list(sys.argv[1:] if argv is None else argv)

    if raw_args and raw_args[0] == "serve":
        parser = argparse.ArgumentParser(description="Run the mdview server.")
        parser.add_argument("command")
        parser.add_argument("--host", default=DEFAULT_HOST)
        parser.add_argument("--port", type=int, default=DEFAULT_PORT)
        return parser.parse_args(raw_args)

    if raw_args and raw_args[0] == "status":
        parser = argparse.ArgumentParser(description="Show mdview server status.")
        parser.add_argument("command")
        return parser.parse_args(raw_args)

    if raw_args and raw_args[0] == "stop":
        parser = argparse.ArgumentParser(description="Stop the mdview server.")
        parser.add_argument("command")
        return parser.parse_args(raw_args)

    parser = argparse.ArgumentParser(description="View a local Markdown file in the browser.")
    parser.add_argument("path", nargs="?", help="Path to a .md or .markdown file.")
    parser.add_argument("--port", type=int, default=DEFAULT_PORT, help=f"Port to bind to. Default: {DEFAULT_PORT}.")
    parser.add_argument("--no-open", action="store_true", help="Do not open the browser automatically.")
    parsed = parser.parse_args(raw_args)
    parsed.command = "open"
    parsed.port_explicit = "--port" in raw_args
    return parsed


def run_server(host: str, port: int) -> int:
    configure_server_logging()
    SERVER_METADATA.update({"host": host, "port": port, "pid": os.getpid(), "started_at": int(time.time())})

    try:
        server = make_server(host, port, APP, threaded=True, request_handler=QuietRequestHandler)
    except OSError as exc:
        raise SystemExit(f"Failed to bind {host}:{port}: {exc}") from exc

    write_state_file(
        build_state_payload(
            host=host,
            port=port,
            pid=int(SERVER_METADATA["pid"]),
            started_at=int(SERVER_METADATA["started_at"]),
        )
    )

    def stop_handler(_signum: int, _frame: object) -> None:
        shutdown_thread = threading.Thread(target=server.shutdown, daemon=True)
        shutdown_thread.start()

    signal.signal(signal.SIGTERM, stop_handler)
    signal.signal(signal.SIGINT, stop_handler)

    try:
        server.serve_forever()
    finally:
        server.server_close()
        remove_state_if_pid_matches(os.getpid())
    return 0


def main() -> int:
    args = parse_args()

    if args.command == "serve":
        return run_server(args.host, args.port)
    if args.command == "status":
        return print_status()
    if args.command == "stop":
        return stop_server()
    return open_target_url(args.path, args.port, args.no_open, args.port_explicit)


if __name__ == "__main__":
    raise SystemExit(main())

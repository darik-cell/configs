HOME_TEMPLATE = """<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>mdview</title>
  <style>{{ base_css|safe }}</style>
</head>
<body class="home-page">
  <main class="home-shell">
    <section class="card">
      <p class="eyebrow">Markdown Viewer</p>
      <h1>Open a local <code>.md</code> file in the browser</h1>
      <p class="lead">Launch with <code>mdview /path/to/file.md</code> or drop a file here.</p>
      {% if error %}
      <div class="flash flash-error">{{ error }}</div>
      {% endif %}
      <form class="path-form" method="get" action="/view">
        <input type="hidden" name="cwd" value="{{ cwd_hint }}">
        <label for="path-input">Path</label>
        <div class="row">
          <input id="path-input" type="text" name="path" placeholder="~/notes/today.md" autocomplete="off">
          <button type="submit">Open</button>
        </div>
        <p class="hint">Relative paths resolve from <code>{{ cwd_hint }}</code>.</p>
      </form>
      <form id="upload-form" class="upload-form" method="post" action="/render-upload" enctype="multipart/form-data">
        <input id="file-input" type="file" name="file" accept=".md,.markdown" hidden>
        <button type="button" id="file-button" class="secondary-button">Choose file</button>
        <button type="submit">Render upload</button>
      </form>
      <div id="drop-zone" class="drop-zone" tabindex="0">
        <strong>Drop a Markdown file</strong>
        <span>Upload stays in memory and is rendered as a standalone document.</span>
      </div>
    </section>
  </main>
  <script>
    const dropZone = document.getElementById("drop-zone");
    const fileInput = document.getElementById("file-input");
    const fileButton = document.getElementById("file-button");

    async function submitFile(file) {
      const body = new FormData();
      body.append("file", file);
      const response = await fetch("/render-upload", {
        method: "POST",
        body
      });
      const markup = await response.text();
      document.open();
      document.write(markup);
      document.close();
    }

    fileButton.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", async () => {
      if (fileInput.files.length) {
        await submitFile(fileInput.files[0]);
      }
    });

    function setDragged(active) {
      dropZone.classList.toggle("dragged", active);
    }

    dropZone.addEventListener("dragenter", (event) => {
      event.preventDefault();
      setDragged(true);
    });

    dropZone.addEventListener("dragover", (event) => {
      event.preventDefault();
      setDragged(true);
    });

    dropZone.addEventListener("dragleave", (event) => {
      event.preventDefault();
      if (event.target === dropZone) {
        setDragged(false);
      }
    });

    dropZone.addEventListener("drop", async (event) => {
      event.preventDefault();
      setDragged(false);
      if (!event.dataTransfer.files.length) {
        return;
      }
      await submitFile(event.dataTransfer.files[0]);
    });

    dropZone.addEventListener("click", () => fileInput.click());
    dropZone.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        fileInput.click();
      }
    });
  </script>
</body>
</html>
"""


VIEW_TEMPLATE = """<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>{{ base_css|safe }}</style>
</head>
<body class="viewer-page">
  <header class="topbar">
    <div>
      <p class="eyebrow">Markdown Viewer</p>
      <h1>{{ source_name }}</h1>
      <p class="subtitle">{{ source_description }}</p>
    </div>
    <div class="topbar-actions">
      {% if reload_href %}
      <a class="action-link" href="{{ reload_href }}">Reload</a>
      {% endif %}
      <a class="action-link" href="{{ open_home_href }}">Open another file</a>
    </div>
  </header>

  {% if source_path and live_update %}
  <div id="status-banner" class="status-banner">Watching for changes.</div>
  {% elif upload_mode %}
  <div class="status-banner">Upload mode: live update is disabled.</div>
  {% endif %}

  <main class="viewer-grid">
    <article id="content" class="markdown-body">{{ content_html|safe }}</article>
    <aside class="toc-card">
      <h2>Contents</h2>
      <div id="toc">{{ toc_html|safe }}</div>
    </aside>
  </main>

  <div id="copy-toast" class="copy-toast" role="status" aria-live="polite" aria-atomic="true"></div>

  <script>
    const copyToast = document.getElementById("copy-toast");
    let copyToastTimer = null;

    function showCopyToast(message, kind = "success") {
      if (!copyToast) {
        return;
      }

      copyToast.textContent = message;
      copyToast.dataset.kind = kind;
      copyToast.classList.add("visible");
      if (copyToastTimer !== null) {
        window.clearTimeout(copyToastTimer);
      }
      copyToastTimer = window.setTimeout(() => {
        copyToast.classList.remove("visible");
      }, 1200);
    }

    function decodeCopyPayload(encoded) {
      const binary = window.atob(encoded);
      const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
      return new TextDecoder().decode(bytes);
    }

    function fallbackCopyText(text) {
      const area = document.createElement("textarea");
      area.value = text;
      area.setAttribute("readonly", "readonly");
      area.style.position = "fixed";
      area.style.top = "-9999px";
      area.style.left = "-9999px";
      document.body.appendChild(area);
      area.focus();
      area.select();
      let ok = false;
      try {
        ok = document.execCommand("copy");
      } finally {
        document.body.removeChild(area);
      }
      return ok;
    }

    document.addEventListener("click", async (event) => {
      const link = event.target.closest(".copy-link");
      if (!link) {
        return;
      }

      event.preventDefault();
      const encoded = link.dataset.copyB64;
      if (!encoded) {
        showCopyToast("Copy failed", "error");
        return;
      }

      let text = "";
      try {
        text = decodeCopyPayload(encoded);
      } catch (_error) {
        showCopyToast("Copy failed", "error");
        return;
      }

      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
        } else if (!fallbackCopyText(text)) {
          throw new Error("Clipboard unavailable");
        }
        showCopyToast("Copied");
      } catch (_error) {
        if (fallbackCopyText(text)) {
          showCopyToast("Copied");
        } else {
          showCopyToast("Copy failed", "error");
        }
      }
    });
  </script>

  {% if source_path and live_update %}
  <script>
    const watchedPath = {{ source_path|tojson }};
    const statusBanner = document.getElementById("status-banner");
    const contentNode = document.getElementById("content");
    const tocNode = document.getElementById("toc");
    let lastMtime = {{ mtime_ns }};
    let pollTimer = null;

    function setStatus(message, kind = "idle") {
      statusBanner.textContent = message;
      statusBanner.dataset.kind = kind;
    }

    async function poll() {
      try {
        const metaResponse = await fetch(`/meta?path=${encodeURIComponent(watchedPath)}`, {
          cache: "no-store",
          headers: { "Accept": "application/json" }
        });

        if (!metaResponse.ok) {
          throw new Error("The source file is no longer readable.");
        }

        const meta = await metaResponse.json();
        if (!meta.exists) {
          throw new Error("The source file no longer exists.");
        }

        if (meta.mtime_ns !== lastMtime) {
          setStatus("Change detected. Refreshing view...", "refreshing");
          const fragmentResponse = await fetch(`/fragment?path=${encodeURIComponent(watchedPath)}`, {
            cache: "no-store",
            headers: { "Accept": "application/json" }
          });
          if (!fragmentResponse.ok) {
            throw new Error("Failed to refresh the document.");
          }

          const fragment = await fragmentResponse.json();
          contentNode.innerHTML = fragment.content_html;
          tocNode.innerHTML = fragment.toc_html;
          document.title = fragment.title;
          lastMtime = fragment.mtime_ns;
          setStatus("Updated automatically.", "updated");
        } else {
          setStatus("Watching for changes.", "idle");
        }
      } catch (error) {
        setStatus(error.message || "Live update failed.", "error");
      } finally {
        pollTimer = window.setTimeout(poll, 1200);
      }
    }

    pollTimer = window.setTimeout(poll, 1200);
    window.addEventListener("beforeunload", () => {
      if (pollTimer !== null) {
        window.clearTimeout(pollTimer);
      }
    });
  </script>
  {% endif %}
</body>
</html>
"""


